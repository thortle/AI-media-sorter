# ============================================================
# Local AI Photo Library - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will never be committed.
# ============================================================

# ------------------------------------------------------------
# Photo Storage
# ------------------------------------------------------------

# Absolute path to the directory that contains your photos on the HOST machine.
# This is mounted into the Docker container and also used by the Moondream
# service (which runs on the host) for AI description generation on uploads.
PHOTO_DIR=/path/to/your/photos

# Path for generated thumbnails (relative to photo-server/).
# Defaults to ./thumbnails if not set.
THUMBNAIL_DIR=./thumbnails

# ------------------------------------------------------------
# Docker / Server Paths (used in docker-compose.yml)
# ------------------------------------------------------------

# Path inside the container where photos are served from.
# You generally do not need to change this.
PHOTO_BASE_PATH=/photos

# Path inside the container for thumbnails.
THUMBNAIL_PATH=/app/thumbnails

# Path inside the container for data files (descriptions, embeddings).
DATA_PATH=/app/data

# Host-side photo directory passed into the container so it can translate
# container paths back to host paths when calling the Moondream service.
# Set this to the same value as PHOTO_DIR above.
HOST_PHOTO_DIR=/path/to/your/photos

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------

# HTTP Basic Auth credentials for the web UI.
# Change these before exposing the server to any network!
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_secure_password

